=====================================================
# CINEMA MANAGEMENT SYSTEM - Environment Configuration
# =====================================================
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Fill in your REAL values
# 3. NEVER commit .env to Git!
# 4. Add .env to .gitignore if not already present
# =====================================================

# DATABASE CONFIGURATION (PostgreSQL)
# -----------------------------------
# For LOCAL development (without Docker)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=cinema_db
DB_USER=cinema
# ⚠️ CHANGE THIS to a strong password!
DB_PASSWORD=your_strong_database_password_here

# For DOCKER development (automatically used by docker-compose)
# Note: In Docker, DB_HOST will be 'postgres' and DB_PORT '5433'
# docker-compose.yml overrides these values

# JWT AUTHENTICATION
# ------------------
# Generate a strong secret: openssl rand -base64 32
# Minimum 32 characters recommended
JWT_SECRET=generate_a_strong_random_secret_key_here

# EMAIL SERVICE (Gmail SMTP)
# --------------------------
# Email address for sending notifications
EMAIL_USERNAME=your.cinema.app@gmail.com

# ⚠️ App Password from Google (NOT your regular password!)
# Create at: https://myaccount.google.com/apppasswords
# Format: 16 characters like "abcd efgh ijkl mnop"
EMAIL_PASSWORD=your_16_digit_google_app_password

# APPLICATION SETTINGS
# --------------------
# Server port (Spring Boot)
SERVER_PORT=8080

# Frontend API URL (React)
REACT_APP_API_URL=http://localhost:8080/api

# =====================================================
# DOCKER USAGE:
# 1. Fill all values above
# 2. Run: docker-compose up -d --build
# 3. Access: http://localhost:3000 (frontend)
#           http://localhost:8080 (backend API)
#           http://localhost:8080/swagger-ui.html (API docs)
# =====================================================

# LOCAL DEVELOPMENT (without Docker):
# 1. Start only database: docker-compose up -d postgres
# 2. Run Spring Boot from your IDE
# 3. Run React: cd frontend && npm run dev
# =====================================================