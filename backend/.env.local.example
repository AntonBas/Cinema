# =====================================================
# CINEMA LOCAL DEVELOPMENT
# =====================================================
# INSTRUCTIONS:
# 1. Copy to .env (in backend/ folder)
# 2. Start Docker PostgreSQL: cd .. && docker-compose up -d postgres
# 3. Run: mvn spring-boot:run
# 4. Access: http://localhost:8080/api
# =====================================================

# DATABASE CONFIGURATION (Docker PostgreSQL)
# ------------------------------------------
# PostgreSQL runs in Docker, port 5433 on host
DB_HOST=localhost
DB_PORT=5433
DB_NAME=cinema_db
DB_USER=cinema
DB_PASSWORD=your_db_password_here          # Must match .env.docker DB_PASSWORD

# JWT AUTHENTICATION
# ------------------
# Generate with: openssl rand -base64 32
JWT_SECRET=your_strong_jwt_secret_min_32_chars_here

# EMAIL SERVICE (SMTP)
# --------------------
# Gmail App Password: https://myaccount.google.com/apppasswords
EMAIL_USERNAME=your.email@gmail.com
EMAIL_PASSWORD=your_google_app_password_here

# LIQPAY PAYMENT CONFIGURATION
# ----------------------------
# Get keys from: https://www.liqpay.ua/en
# Sandbox keys start with 'sandbox_'
LIQPAY_PUBLIC_KEY=sandbox_i1234567890abcdef
LIQPAY_PRIVATE_KEY=sandbox_1234567890abcdef
LIQPAY_SANDBOX_MODE=true

# Ngrok URL for local webhooks (get from: ngrok http 8080)
PAYMENT_LIQPAY_CALLBACK_URL=https://your-ngrok-domain.ngrok-free.dev/api/liqpay/callback
PAYMENT_LIQPAY_RESULT_URL=http://localhost:5173/booking/success

# FRONTEND URL
# ---------------------------
FRONTEND_URL=http://localhost:5173

# GOOGLE OAUTH CONFIGURATION
# --------------------------
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=GOCSPX-your_google_client_secret