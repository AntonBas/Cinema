# =====================================================
# CINEMA LOCAL DEVELOPMENT WITH DOCKER POSTGRESQL
# =====================================================
# INSTRUCTIONS:
# 1. Copy to .env.local (in backend/ folder)
# 2. Start Docker PostgreSQL: docker-compose --env-file ../.env.docker up -d postgres
# 3. Run: mvn spring-boot:run -Dspring-boot.run.profiles=local
# 4. Access: http://localhost:8080/api
# =====================================================

# DATABASE CONFIGURATION (Docker PostgreSQL)
# ------------------------------------------
DB_HOST=localhost            # Docker PostgreSQL exposed on host
DB_PORT=5433                # Docker port (from .env.docker: DB_HOST_PORT=5433)
DB_NAME=cinema_db
DB_USER=cinema
DB_PASSWORD=docker_db_password_here  # Must match .env.docker DB_PASSWORD

# JWT AUTHENTICATION
# ------------------
JWT_SECRET=your_strong_jwt_secret_min_32_chars_here

# EMAIL SERVICE (SMTP)
# --------------------
EMAIL_USERNAME=your.email@gmail.com
EMAIL_PASSWORD=your_google_app_password_here