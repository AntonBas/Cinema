# =====================================================
# CINEMA DOCKER ENVIRONMENT
# =====================================================
# INSTRUCTIONS:
# 1. Copy to .env.docker (NOT .env!)
# 2. Fill values, then: docker-compose --env-file .env.docker up
# 3. NEVER commit .env.docker to Git!
# =====================================================

# DATABASE CONFIGURATION
# ----------------------
DB_HOST=postgres              # Container name in Docker network
DB_PORT=5432                 # Port inside container
DB_NAME=cinema_db
DB_USER=cinema
DB_PASSWORD=your_strong_db_password_here

# CONTAINER PORTS (mapped to your computer)
# ------------------------------------------
DB_HOST_PORT=5433            # Access from host: localhost:5433
BACKEND_HOST_PORT=8080       # Backend API: localhost:8080
FRONTEND_HOST_PORT=5173      # Frontend: localhost:5173

# JWT AUTHENTICATION
# ------------------
JWT_SECRET=your_strong_jwt_secret_min_32_chars_here

# EMAIL SERVICE (SMTP)
# --------------------
EMAIL_USERNAME=your.email@gmail.com
EMAIL_PASSWORD=your_google_app_password_here

# =====================================================
# QUICK START:
# 1. cp .env.docker.example .env.docker
# 2. Fill all values
# 3. docker-compose --env-file .env.docker up --build
# 4. Access:
#    - Backend API: http://localhost:8080/api
#    - Frontend:    http://localhost:5173
#    - API Docs:    http://localhost:8080/swagger-ui.html
#    - Database:    localhost:5433 (user: cinema, db: cinema_db)
# =====================================================