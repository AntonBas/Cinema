# =====================================================
# CINEMA DOCKER ENVIRONMENT
# =====================================================
# INSTRUCTIONS:
# 1. Copy to .env.docker
# 2. Fill values, then: docker-compose up -d
# 3. NEVER commit .env.docker to Git!
# =====================================================

# DATABASE CONFIGURATION
# ----------------------
DB_HOST=postgres
DB_PORT=5432
DB_NAME=cinema_db
DB_USER=cinema
DB_PASSWORD=your_db_password_here

DB_HOST_PORT=5433

# BACKEND
# -------
BACKEND_HOST_PORT=8080
JWT_SECRET=your_jwt_secret_here

# EMAIL
# -----
EMAIL_USERNAME=your.email@gmail.com
EMAIL_PASSWORD=your_app_password_here

# FRONTEND
# --------
FRONTEND_HOST_PORT=5173
FRONTEND_URL=http://localhost:5173

# LIQPAY
# ------
LIQPAY_PUBLIC_KEY=sandbox_i1234567890abcdef
LIQPAY_PRIVATE_KEY=sandbox_1234567890abcdef
LIQPAY_SANDBOX_MODE=true
PAYMENT_LIQPAY_CALLBACK_URL=https://your-domain.ngrok-free.dev/api/liqpay/callback
PAYMENT_LIQPAY_RESULT_URL=http://localhost:5173/booking/success

# GOOGLE OAUTH
# ------------
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_client_secret

# APP
# ---
APP_BASE_URL=http://localhost:8080

# NGROK
# -----
NGROK_AUTH_TOKEN=your_token_here

# =====================================================
# WHERE TO GET VALUES:
# =====================================================
# DB_PASSWORD      - any password
# JWT_SECRET       - run: openssl rand -base64 32
# EMAIL_PASSWORD   - https://myaccount.google.com/apppasswords
# LIQPAY_*         - https://www.liqpay.ua/en
# GOOGLE_*         - https://console.cloud.google.com/apis/credentials
# NGROK_AUTH_TOKEN - https://dashboard.ngrok.com/get-started/your-authtoken
# =====================================================